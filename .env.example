# ── ANTHROPIC ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # Tu API key de Anthropic (console.anthropic.com)

# ── TELEGRAM ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # Token del bot (@BotFather → /newbot)
TELEGRAM_CHAT_ID=            # Tu chat ID personal (@userinfobot te lo da)
TELEGRAM_WEBHOOK_SECRET=     # Generado automáticamente por setup.sh (no tocar)

# ── SPOTIFY ────────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=           # Spotify Developer Dashboard → Create App (gratis)
SPOTIFY_CLIENT_SECRET=       # Spotify Developer Dashboard → Create App (gratis)
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback   # Para autenticación inicial

# ── YOUTUBE ────────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=             # Google Cloud Console → YouTube Data API v3 (gratis, 10k/día)

# ── PODCAST DISCOVERY ──────────────────────────────────────────────────────────
LISTENNOTES_API_KEY=         # listen-api.com → plan Free (10k calls/mes)
PODCASTINDEX_API_KEY=        # podcastindex.org → registro gratis
PODCASTINDEX_API_SECRET=     # podcastindex.org → registro gratis

# ── APPLE CALENDAR (CalDAV, solo lectura) ──────────────────────────────────────
APPLE_CALDAV_URL=https://caldav.icloud.com
APPLE_CALDAV_USER=           # Tu Apple ID (email)
APPLE_CALDAV_PASSWORD=       # Contraseña específica de app: appleid.apple.com → Seguridad → App-Specific Passwords
APPLE_CALENDAR_NAME=Personal

# ── N8N ────────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=     # Elige una contraseña segura (mínimo 12 caracteres)
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=             # URL pública HTTPS (ngrok: https://xxx.ngrok.io, cloudflare tunnel: https://xxx.trycloudflare.com)
N8N_BASIC_AUTH_ACTIVE=true

# ── EMAIL (opcional) ───────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
